CREATE TABLE Exams
(
    Id INT IDENTITY(1,1) PRIMARY KEY,

    TeachingAssignmentId INT NOT NULL,

    ExamName NVARCHAR(100) NOT NULL,

    ExamType NVARCHAR(50) NOT NULL,

    ExamDate DATE NOT NULL,

    MaximumMarks DECIMAL(5,2) NOT NULL,

    PassingMarks DECIMAL(5,2) NOT NULL,

    Description NVARCHAR(500) NULL,

    CreatedDate DATETIME2 NOT NULL
        DEFAULT SYSUTCDATETIME(),

    CreatedBy NVARCHAR(100) NULL,

    UpdatedDate DATETIME2 NULL,

    UpdatedBy NVARCHAR(100) NULL,

    IsActive BIT NOT NULL DEFAULT(1),

    IsDeleted BIT NOT NULL DEFAULT(0),

    CONSTRAINT FK_Exams_TeachingAssignments
        FOREIGN KEY(TeachingAssignmentId)
        REFERENCES TeachingAssignments(Id)
);
GO

CREATE INDEX IX_Exams_TeachingAssignment
ON Exams(TeachingAssignmentId);

CREATE INDEX IX_Exams_ExamDate
ON Exams(ExamDate);
GO